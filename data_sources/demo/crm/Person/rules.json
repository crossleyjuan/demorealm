{
    "collection": "Person",
    "database": "crm",
    "roles": [
        {
            "name": "owner",
            "apply_when": {
                "userId": "%%user.id"
            },
            "read": true,
            "write": true,
            "insert": true,
            "delete": true,
            "search": true,
            "additional_fields": {}
        },
        {
            "name": "owner2",
            "apply_when": {
                "userId": "1"
            },
            "read": true,
            "write": false,
            "insert": true,
            "delete": true,
            "search": true,
            "additional_fields": {}
        }
    ]
}
